{
  "name": "dpg-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dpg-starter": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@francav/bpmn-js-adapter": "*",
    "@francav/components": "git+https://github.com/francav/dpg-components.git#v0.1.4"
  },
  "peerDependencies": {
    "bpmn-js": ">=11"
  },
  "peerDependenciesMeta": {
    "bpmn-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "jsdom": "^25"
  }
}
